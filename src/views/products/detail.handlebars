<div class="detalle-producto-contenedor">

  <div>
    <div
      class="imagen-detalle-principal"
      style="display: flex; align-items: center; justify-content: center; font-size: 5rem;"
    >
      💻
    </div>
  </div>

  <div class="info-producto">
    <span class="categoria-etiqueta">{{mayusculas product.category}}</span>
    <h2>{{product.title}}</h2>
    <p class="marca-detalle"><strong>Código de referencia:</strong> {{product.code}}</p>

    <p class="descripcion-corta" style="font-size: 1.1rem; line-height: 1.6; color: #334155;">
      {{product.description}}
    </p>

    <div class="bloque-compra">
      <span class="precio-grande">${{product.price}}</span>

      {{#if product.stock}}
        <p class="alerta-stock disponible">🟢 Stock Disponible: {{product.stock}} unidades</p>
        <button onclick="agregarAlCarrito('{{product._id}}')" class="btn-comprar">
          🛒 Agregar al Carrito
        </button>
      {{else}}
        <p class="alerta-stock agotado">🔴 Producto agotado temporalmente</p>
        <button class="btn-comprar" disabled>Sin Stock</button>
      {{/if}}
    </div>

    <a href="/products" class="enlace-volver">🔙 Volver al catálogo</a>
  </div>
</div>

<script src="/js/detail.js"></script>